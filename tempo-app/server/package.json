{
  "name": "tempo-server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "TEMPO backend — Express + SQLite API mirroring the frontend data shapes",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "migrate": "node db/migrate.js",
    "seed": "node db/seed.js",
    "reset": "rm -f tempo.db && npm run migrate && npm run seed",
    "test:api": "node test/api.test.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.2"
  }
}
