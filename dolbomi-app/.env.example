# DOLBOMI — frontend environment (Vite). Copy to .env.local for local dev, and
# set the same two vars in Vercel → Project → Settings → Environment Variables.
#
# Find these in Supabase → Project Settings → Data API / API Keys.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
